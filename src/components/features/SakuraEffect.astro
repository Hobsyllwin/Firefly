---
import { sakuraConfig } from "@/config";

const config = sakuraConfig;
---

<script is:inline define:vars={{ sakuraConfig: config }}>
		let windowWidth = window.innerWidth;
		let windowHeight = window.innerHeight;

		// 废土粒子类：灰烬尘埃(下沉) + 余烬火星(上升、发光、闪烁)
		class Particle {
			constructor(config) {
				this.config = config;
				this.reset(true);
			}

			// initial=true 时铺满全屏(首次生成)，否则从入场边缘生成
			reset(initial) {
				const c = this.config;
				// 约 16% 概率为"余烬火星"，其余为"灰烬尘埃"
				this.ember = Math.random() < 0.16;

				// 半径(px)，复用 size.min/max 作为像素范围
				const sMin = c.size?.min ?? 0.6;
				const sMax = c.size?.max ?? 2.6;
				this.radius = sMin + Math.random() * (sMax - sMin);
				// 火星略大一点
				if (this.ember) this.radius *= 1.3;

				// 基础透明度，复用 opacity.min/max
				const aMin = c.opacity?.min ?? 0.1;
				const aMax = c.opacity?.max ?? 0.6;
				this.baseAlpha = aMin + Math.random() * (aMax - aMin);
				this.alpha = this.baseAlpha;

				// 水平漂移 + 正弦摆动
				const hMin = c.speed?.horizontal?.min ?? -0.3;
				const hMax = c.speed?.horizontal?.max ?? 0.3;
				this.vx = hMin + Math.random() * (hMax - hMin);
				this.swayPhase = Math.random() * Math.PI * 2;
				this.swaySpeed = 0.005 + Math.random() * 0.015;
				this.swayAmp = 0.15 + Math.random() * 0.35;

				// 垂直速度：尘埃下沉，火星上升
				const vMin = c.speed?.vertical?.min ?? 0.15;
				const vMax = c.speed?.vertical?.max ?? 0.5;
				if (this.ember) {
					this.vy = -(0.12 + Math.random() * 0.35); // 上升
				} else {
					this.vy = vMin + Math.random() * (vMax - vMin); // 下沉
				}

				// 火星闪烁
				this.flickerPhase = Math.random() * Math.PI * 2;
				this.flickerSpeed = 0.04 + Math.random() * 0.06;

				// 颜色：尘埃=暗灰褐，火星=琥珀橙
				if (this.ember) {
					const embers = ['255,150,60', '255,120,40', '255,180,90'];
					this.color = embers[(Math.random() * embers.length) | 0];
				} else {
					const ash = ['170,158,138', '140,134,124', '120,112,98', '150,140,120'];
					this.color = ash[(Math.random() * ash.length) | 0];
				}

				// 位置
				if (initial) {
					this.x = Math.random() * windowWidth;
					this.y = Math.random() * windowHeight;
				} else if (this.ember) {
					// 火星从底部入场
					this.x = Math.random() * windowWidth;
					this.y = windowHeight + 10;
				} else {
					// 尘埃从顶部/侧边入场
					if (Math.random() > 0.35) {
						this.x = Math.random() * windowWidth;
						this.y = -10;
					} else {
						this.x = this.vx >= 0 ? -10 : windowWidth + 10;
						this.y = Math.random() * windowHeight * 0.6;
					}
				}
			}

			update() {
				this.swayPhase += this.swaySpeed;
				this.x += this.vx + Math.sin(this.swayPhase) * this.swayAmp;
				this.y += this.vy;

				if (this.ember) {
					this.flickerPhase += this.flickerSpeed;
					this.alpha = this.baseAlpha * (0.5 + 0.5 * Math.abs(Math.sin(this.flickerPhase)));
				} else {
					this.alpha = this.baseAlpha;
				}

				// 出界重生
				if (
					this.y > windowHeight + 12 ||
					this.y < -12 ||
					this.x < -12 ||
					this.x > windowWidth + 12
				) {
					this.reset(false);
				}
			}

			draw(ctx) {
				ctx.save();
				ctx.globalAlpha = Math.max(0, Math.min(1, this.alpha));
				if (this.ember) {
					ctx.shadowBlur = this.radius * 5;
					ctx.shadowColor = 'rgba(255,140,50,0.9)';
				}
				ctx.fillStyle = `rgb(${this.color})`;
				ctx.beginPath();
				ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
				ctx.fill();
				ctx.restore();
			}
		}

		// 粒子管理器
		class SakuraManager {
			constructor(config) {
				this.config = config;
				this.canvas = null;
				this.ctx = null;
				this.particles = [];
				this.animationId = null;
				this.isRunning = false;
			}

			init() {
				if (!this.config.enable || this.isRunning) {
					return;
				}
				this.createCanvas();
				this.createParticles();
				this.startAnimation();
				this.isRunning = true;
			}

			createCanvas() {
				this.canvas = document.createElement('canvas');
				this.canvas.height = windowHeight;
				this.canvas.width = windowWidth;
				this.canvas.setAttribute('style', `position: fixed; left: 0; top: 0; pointer-events: none; z-index: ${this.config.zIndex}; transform: translateZ(0);`);
				this.canvas.setAttribute('id', 'canvas_sakura');
				document.body.appendChild(this.canvas);
				this.ctx = this.canvas.getContext('2d');

				this._boundHandleResize = this.handleResize.bind(this);
				window.addEventListener('resize', this._boundHandleResize);
			}

			createParticles() {
				this.particles = [];
				const num = this.config.sakuraNum || 60;
				for (let i = 0; i < num; i++) {
					this.particles.push(new Particle(this.config));
				}
			}

			startAnimation() {
				if (!this.ctx || !this.canvas) return;
				const animate = () => {
					if (!this.ctx || !this.canvas) return;
					this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
					for (let i = 0; i < this.particles.length; i++) {
						this.particles[i].update();
						this.particles[i].draw(this.ctx);
					}
					this.animationId = requestAnimationFrame(animate);
				};
				this.animationId = requestAnimationFrame(animate);
			}

			handleResize() {
				windowWidth = window.innerWidth;
				windowHeight = window.innerHeight;
				if (this.canvas) {
					this.canvas.width = windowWidth;
					this.canvas.height = windowHeight;
				}
			}

			stop() {
				if (this.animationId) {
					cancelAnimationFrame(this.animationId);
					this.animationId = null;
				}
				if (this.canvas) {
					document.body.removeChild(this.canvas);
					this.canvas = null;
				}
				if (this._boundHandleResize) {
					window.removeEventListener('resize', this._boundHandleResize);
					this._boundHandleResize = null;
				}
				this.particles = [];
				this.isRunning = false;
			}

			toggle() {
				if (this.isRunning) {
					this.stop();
				} else {
					this.init();
				}
			}

			updateConfig(newConfig) {
				const wasRunning = this.isRunning;
				if (wasRunning) {
					this.stop();
				}
				this.config = newConfig;
				if (wasRunning && newConfig.enable) {
					this.init();
				}
			}

			getIsRunning() {
				return this.isRunning;
			}
		}

		// 全局实例
		let globalSakuraManager = null;
		window.sakuraManager = null;

		function initSakura(config) {
			if (globalSakuraManager) {
				globalSakuraManager.updateConfig(config);
			} else {
				globalSakuraManager = new SakuraManager(config);
				window.sakuraManager = globalSakuraManager;
				if (config.enable) {
					globalSakuraManager.init();
				}
			}
		}

		// 初始化(只执行一次)
		(function() {
			if (window.sakuraInitialized) {
				return;
			}
			const setupSakura = () => {
				if (window.sakuraInitialized) return;
				// 读取用户在设置面板中的开关偏好
				var storedEnabled = localStorage.getItem("sakuraEnabled");
				var isEnabled = storedEnabled !== null ? storedEnabled === "true" : sakuraConfig.enable;
				var cfg = Object.assign({}, sakuraConfig, { enable: isEnabled });
				initSakura(cfg);
				window.sakuraInitialized = true;
			};

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', setupSakura);
			} else {
				setupSakura();
			}
		})();

		// 监听设置面板的特效切换事件
		window.addEventListener('sakuraToggle', function(e) {
			var enabled = e.detail.enabled;
			var mgr = window.sakuraManager;
			if (!mgr) return;
			if (enabled && !mgr.getIsRunning()) {
				mgr.config.enable = true;
				mgr.init();
			} else if (!enabled && mgr.getIsRunning()) {
				mgr.stop();
			}
		});
	</script>
